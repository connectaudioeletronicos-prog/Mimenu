# ===================================================================
# VARIAVEIS DE AMBIENTE - copie este arquivo para ".env" e preencha
# NUNCA suba o arquivo ".env" real para o GitHub
# ===================================================================

PORT=3000

DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

JWT_SECRET=troque_esta_chave_por_uma_string_aleatoria_e_longa

# Chave MESTRA usada so por voce para gerar links de convite de cadastro.
# NUNCA compartilhe com o lojista -- ela nao aparece em nenhum link.
CHAVE_CADASTRO_ADMIN=troque_por_uma_senha_forte_so_sua

MP_ACCESS_TOKEN=seu_access_token_do_mercado_pago
MP_PUBLIC_KEY=sua_public_key_do_mercado_pago

FRONTEND_URL=http://localhost:5500

GOOGLE_MAPS_API_KEY=sua_chave_da_google_geocoding_api

# Credenciais do cliente OAuth "Palatos Web Client" (Google Cloud > Auth
# Platform > Clientes). O CLIENT_ID tambem esta hardcoded no frontend
# (frontend/js/config.js) - nao e segredo. O CLIENT_SECRET e sensivel e
# so deve existir aqui e nas variaveis de ambiente do Render.
GOOGLE_CLIENT_ID=903108778717-t74g7vt3o16fkh86pkcvv8ompc15i925.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=cole_aqui_o_secreto_do_cliente_copiado_do_google_cloud

RESEND_API_KEY=sua_chave_da_resend
RESEND_FROM_EMAIL=onboarding@resend.dev

NODE_ENV=development
